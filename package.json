{
  "name": "pi-dstatus",
  "version": "0.0.2",
  "description": "Configurable multi-line Powerline status bar extension for Pi",
  "repository": { "type": "git", "url": "https://github.com/ssdiwu/pi-dstatus.git" },
  "homepage": "https://github.com/ssdiwu/pi-dstatus#readme",
  "bugs": { "url": "https://github.com/ssdiwu/pi-dstatus/issues" },
  "type": "module",
  "main": "extensions/index.ts",
  "module": "extensions/index.ts",
  "files": [
    "extensions",
    "src",
    "README.md",
    "AGENTS.md",
    "doc",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run typecheck && npm test"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "statusbar",
    "status-bar",
    "footer",
    "powerline"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
